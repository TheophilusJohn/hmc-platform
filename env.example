# ─── DATABASE ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://hmc_user:your_db_password@localhost:5432/hmc_db
DB_PASSWORD=your_secure_db_password_here

# ─── AUTHENTICATION ───────────────────────────────────────────────────────────
JWT_SECRET=your-256-bit-secret-generate-with-openssl-rand-hex-32
JWT_EXPIRES_IN=8h
ENCRYPTION_KEY=your-32-char-aes256-key-for-pii-fields

# ─── SENDGRID (EMAIL) ─────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@hmc.edu
SENDGRID_FROM_NAME=Harvest Mission College

# ─── MSG91 (INDIA SMS) ────────────────────────────────────────────────────────
MSG91_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxx
MSG91_SENDER_ID=HMC
MSG91_TEMPLATE_ID=your_template_id

# ─── TWILIO (INTERNATIONAL SMS) ───────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ─── WHATSAPP BUSINESS API ────────────────────────────────────────────────────
WHATSAPP_BUSINESS_ID=xxxxxxxxxxxxx
WHATSAPP_ACCESS_TOKEN=xxxxxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=xxxxxxxxxxxxx

# ─── RAZORPAY ─────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
# For test mode: rzp_test_xxxxxxxxxxxxxxxxxx

# ─── WISE (INTERNATIONAL PAYMENTS) ───────────────────────────────────────────
WISE_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
WISE_PROFILE_ID=xxxxxxxxxx
# Default to Wise's sandbox so test deployments can't accidentally hit the
# production gateway. Switch to https://api.wise.com only in production.
WISE_API_URL=https://api.sandbox.transferwise.tech

# ─── COPYLEAKS (PLAGIARISM) ───────────────────────────────────────────────────
COPYLEAKS_EMAIL=your-email@hmc.edu
COPYLEAKS_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ─── MINIO (FILE STORAGE) ─────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USER=hmc_minio_admin
MINIO_PASSWORD=your_secure_minio_password
MINIO_BUCKET=hmc-files
MINIO_USE_SSL=false
# For production with SSL: MINIO_USE_SSL=true

# ─── APPLICATION ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000
CLIENT_URL=https://hmc.edu
